import {
  "gmlewis/fonts/canvas",
  "gmlewis/fonts/draw",
  "gmlewis/fonts/geom",
  "gmlewis/fonts/examples/checkerboard",
  "moonbitlang/core/builtin",
}

supported_targets = "+wasm+wasm-gc"

options(
  "is-main": true,
  link: {
    "wasm": { "exports": [ "draw" ] },
    "wasm-gc": { "exports": [ "draw" ] },
  },
)
